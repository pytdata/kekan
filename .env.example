# ─── App Identity ─────────────────────────────────────────────────────────────
VITE_APP_ID=your-app-id
VITE_APP_NAME=Kenkan Books

# ─── GraphQL / Backend API ────────────────────────────────────────────────────
# Leave empty to use the built-in in-memory mock (no server required)
# Set to your Express server URL when running the real backend
VITE_GRAPHQL_URL=http://localhost:4000/graphql

# ─── Paystack (Payments) ──────────────────────────────────────────────────────
# Get keys from https://dashboard.paystack.com/#/settings/developer
VITE_PAYSTACK_PUBLIC_KEY=pk_test_YOUR_PAYSTACK_PUBLIC_KEY

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# ─── Apple Sign-In ────────────────────────────────────────────────────────────
# Configure at https://developer.apple.com/account/resources/identifiers/list
VITE_APPLE_CLIENT_ID=com.kenkan.books

# ─── Feature Flags ────────────────────────────────────────────────────────────
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_SUBSCRIPTIONS=true
VITE_ENABLE_SOCIAL_LOGIN=true
