# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite (default — path relative to server root):
DATABASE_URL=sqlite://db/kenkan.db
# PostgreSQL (uncomment and fill when migrating):
# DATABASE_URL=postgresql://user:password@localhost:5432/kenkan_db

# ─── Auth / JWT ───────────────────────────────────────────────────────────────
# Use a long random string in production: openssl rand -hex 64
JWT_SECRET=your-random-64-char-secret
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ─── File Uploads ─────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=50

# ─── Paystack (Payments) ──────────────────────────────────────────────────────
# Get keys from https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY=sk_test_YOUR_PAYSTACK_SECRET_KEY
PAYSTACK_PUBLIC_KEY=pk_test_YOUR_PAYSTACK_PUBLIC_KEY
PAYSTACK_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# ─── Email / OTP (SMTP) ───────────────────────────────────────────────────────
# Used for sending OTP verification emails
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@kenkan.com
SMTP_PASS=your-smtp-password
EMAIL_FROM=Kenkan Books <noreply@kenkan.com>

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=xxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-YOUR_GOOGLE_CLIENT_SECRET

# ─── Apple Sign-In ────────────────────────────────────────────────────────────
APPLE_CLIENT_ID=com.kenkan.books
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_KEY_ID=XXXXXXXXXX
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXXX\n-----END PRIVATE KEY-----"

# ─── Admin Seed ───────────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@kenkan.com
SEED_ADMIN_PASSWORD=your-admin-password
